      <geom name="g11_disk_visual" type="mesh" mesh="g11_disk_visual" material="object_material" mass="0" class="visual"/>
      <!-- <geom name="g1112_disk_collision" type="mesh" mesh="g1112_disk_collision" class="collision" density="248"/> -->
